# Database — required
DATABASE_URL="mysql://username:password@hostname:port/database_name"

# SMTP — order confirmation emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="replace-with-app-password"
SMTP_FROM="Storefront <no-reply@example.com>"

# Toggle order email notifications (true / false)
NOTIFY_ON_ORDER="true"

# NextAuth (placeholder — not yet used)
NEXTAUTH_SECRET="generate-a-secure-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Admin write lock
ADMIN_WRITE_ENABLED="true"
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_SCORE_THRESHOLD="0.5"
RECAPTCHA_ALLOWED_HOSTNAMES="localhost,127.0.0.1"
# Development only. Never enable in production.
RECAPTCHA_DEVELOPMENT_BYPASS="false"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SHADOW_MODE="true"
INTERNAL_METRICS_TOKEN=""
PUBLIC_CACHE_MAX_ITEMS="300"
PUBLIC_CACHE_MAX_BYTES="67108864"
RATE_LIMIT_ORDER_IP="120"
RATE_LIMIT_ORDER_PHONE="8"
RATE_LIMIT_COMBO_ORDER_IP="120"
RATE_LIMIT_COMBO_ORDER_PHONE="8"
RATE_LIMIT_CART_QUOTE_IP="180"
STOREFRONT_ORIGIN="https://example.com"
SEARCH_WEBHOOK_SECRET="replace-with-at-least-32-random-bytes"
DB_CONNECTION_LIMIT="12"
DB_QUEUE_LIMIT="500"
DB_CONNECT_TIMEOUT_MS="5000"
BACKGROUND_WORKER_POLL_MS="2000"
VIETNAM_LOCATION_API_BASE="https://provinces.open-api.vn/api/v2"
VIETNAM_LOCATION_CACHE_TTL_MS="86400000"
# Optional legacy-import overrides. Snapshots are local audit artifacts and are ignored by Git.
LEGACY_IMPORT_PCMARKET_CATEGORY_URL="https://pcmarket.vn/export/product_category.php"
LEGACY_IMPORT_PCMARKET_ARTICLE_CATEGORY_URL="https://pcmarket.vn/export/article_category.php"
LEGACY_IMPORT_PCMARKET_ARTICLE_URL="https://pcmarket.vn/export/article.php"
LEGACY_IMPORT_ARTIFACT_DIR=""
# Destructive integration tests require both an explicitly disposable URL and opt-in flag.
LEGACY_IMPORT_TEST_DATABASE_URL=""
LEGACY_ARTICLE_IMPORT_TEST_DATABASE_URL=""
LEGACY_IMPORT_DESTRUCTIVE_TEST="false"
# Category-only cutover smoke mode; default healthcheck behavior remains strict when false.
LOCAL_HEALTHCHECK_EMPTY_CATALOG="false"
LOCAL_HEALTHCHECK_CATEGORY_ID="6"
