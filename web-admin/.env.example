# Database — required
DATABASE_URL="mysql://username:password@hostname:port/database_name"

# SMTP — order confirmation emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="replace-with-app-password"
SMTP_FROM="Storefront <no-reply@example.com>"

# Toggle order email notifications (true / false)
NOTIFY_ON_ORDER="true"

# NextAuth (placeholder — not yet used)
NEXTAUTH_SECRET="generate-a-secure-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Admin write lock
ADMIN_WRITE_ENABLED="true"
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_SCORE_THRESHOLD="0.5"
RECAPTCHA_ALLOWED_HOSTNAMES="localhost,127.0.0.1"
# Development only. Never enable in production.
RECAPTCHA_DEVELOPMENT_BYPASS="false"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SHADOW_MODE="true"
STOREFRONT_ORIGIN="https://example.com"
SEARCH_WEBHOOK_SECRET="replace-with-at-least-32-random-bytes"
DB_CONNECTION_LIMIT="12"
DB_QUEUE_LIMIT="500"
DB_CONNECT_TIMEOUT_MS="5000"
BACKGROUND_WORKER_POLL_MS="2000"
VIETNAM_LOCATION_API_BASE="https://provinces.open-api.vn/api/v2"
VIETNAM_LOCATION_CACHE_TTL_MS="86400000"
