    "tinymce": "^8.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^9",
