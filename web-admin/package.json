    "local:benchmark": "tsx scripts/benchmark-local-server.ts",
    "db:indexes": "tsx scripts/ensure-local-performance-indexes.ts",
    "db:explain-hot": "tsx scripts/explain-hot-queries.ts",
    "storefront:benchmark": "tsx scripts/benchmark-storefront.ts",
