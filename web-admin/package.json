{
  "name": "admin-dashboard",
  "version": "0.1.0",
  "private": true,
  "overrides": { "postcss": "8.5.10" },
  "scripts": {
    "dev": "node scripts/dev-with-worker.mjs",
    "dev:api": "next dev",
    "dev:clean": "node scripts/clean-next-dev-cache.mjs && node scripts/dev-with-worker.mjs",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "admin:migrate": "tsx scripts/run-admin-migration.ts",
    "locations:sync": "tsx scripts/sync-vietnam-locations.ts",
